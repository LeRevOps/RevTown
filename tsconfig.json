{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["core/**/*.ts", "cli/**/*.ts", "agents/**/*.ts"],
  "exclude": ["node_modules", "examples"]
}
